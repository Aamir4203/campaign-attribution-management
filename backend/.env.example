# CAM Backend Environment Variables
# Copy this file to .env for development or .env.production for production

# Database Configuration
CAM_DB_HOST=zds-prod-pgdb01-01.bo3.e-dialog.com
CAM_DB_PORT=5432
CAM_DB_NAME=apt_tool_db
CAM_DB_USER=datateam
CAM_DB_PASSWORD=Datat3amSU!

# Server Configuration
CAM_API_PORT=5000
CAM_FRONTEND_PORT=3009
CAM_DEBUG=true
CAM_ENVIRONMENT=development

# File Upload Configuration
REPORT_FILES_PATH=REPORT_FILES
MAX_FILE_SIZE_MB=50

# Snowflake Configuration - Production Account
SF_ACCOUNT=your_snowflake_account.region
SF_USER=your_snowflake_user
SF_PASSWORD=your_snowflake_password
SF_WAREHOUSE=your_warehouse
SF_DATABASE=your_database
SF_SCHEMA=your_schema
SF_ROLE=your_role
# Private Key Authentication (recommended)
SF_PRIVATE_KEY_PATH=backend/.snowflake/rsa_key.p8
SF_PRIVATE_KEY_PASSPHRASE=your_passphrase

# Snowflake Configuration - Audit LPT Account
SF_AUDIT_ACCOUNT=your_audit_account.region
SF_AUDIT_USER=your_audit_user
SF_AUDIT_WAREHOUSE=your_audit_warehouse
SF_AUDIT_DATABASE=your_audit_database
SF_AUDIT_SCHEMA=your_audit_schema
SF_AUDIT_ROLE=your_audit_role
# Private Key Authentication for Audit
SF_AUDIT_PRIVATE_KEY_PATH=backend/.snowflake/lpt_rsa_key.p8
SF_AUDIT_PRIVATE_KEY_PASSPHRASE=your_audit_passphrase
